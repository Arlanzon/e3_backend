// =============================================================================
// schema.prisma
// Plataforma Gastronómica Local — Oaxaca
// Modelos: User + UserRestaurant + Restaurant + BusinessHour
// Versión: 1.2.0
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

/// Rol global del usuario en la plataforma.
/// - CUSTOMER : comensal, puede explorar y reservar
/// - OWNER    : propietario, puede crear y administrar restaurantes
/// - MANAGER  : encargado, asignado a un restaurante por un OWNER
/// - ADMIN    : control interno de la plataforma (moderación, soporte)
enum UserRole {
  CUSTOMER
  OWNER
  MANAGER
  ADMIN
}

/// Rol específico dentro de un restaurante.
/// Vive en UserRestaurant, no en User, porque un mismo usuario
/// puede ser OWNER en un restaurante y MANAGER en otro.
enum StaffRole {
  OWNER
  MANAGER
}

/// Estado del restaurante en la plataforma.
enum RestaurantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

/// Días de la semana para business_hours.
enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// =============================================================================
// USER
// =============================================================================

/// Representa a cualquier persona registrada en la plataforma.
/// El rol global (UserRole) define el tipo de cuenta.
/// Los permisos por restaurante se manejan en UserRestaurant.
model User {
  // ── Identidad ──────────────────────────────────────────────────────────────
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(100)
  email        String   @unique @db.VarChar(150)
  passwordHash String   @db.VarChar(255) @map("password_hash")

  // ── Rol y estado ───────────────────────────────────────────────────────────
  role         UserRole @default(CUSTOMER)

  /// false = cuenta desactivada. No se eliminan registros para preservar
  /// el historial de reservaciones y reseñas asociadas.
  active       Boolean  @default(true)

  // ── Perfil ─────────────────────────────────────────────────────────────────
  /// URL de Cloudinary. Null hasta que el usuario sube una foto.
  photoUrl     String?  @db.VarChar(255) @map("photo_url")

  // ── Timestamps ─────────────────────────────────────────────────────────────
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt      @map("updated_at")

  // ── Relaciones ─────────────────────────────────────────────────────────────
  restaurantStaff UserRestaurant[]

  // Relaciones futuras (se descomentan en su iteración correspondiente):
  // reservations    Reservation[]
  // reviews         Review[]
  // reviewReports   ReviewReport[]
  // reviewResponses ReviewResponse[]

  @@map("users")
}

// =============================================================================
// USER_RESTAURANT
// =============================================================================

/// Vincula un User con un Restaurant y define su nivel de acceso.
///
/// Casos que resuelve:
///   1. Propietario con múltiples restaurantes:
///      → mismo userId, múltiples filas con permissionRole = OWNER
///   2. Encargado asignado a un restaurante específico:
///      → userId + restaurantId únicos, permissionRole = MANAGER
///   3. Baja de encargado sin perder historial:
///      → active = false, el registro permanece
model UserRestaurant {
  // ── Identidad ──────────────────────────────────────────────────────────────
  id             String    @id @default(uuid()) @db.Uuid

  // ── Claves foráneas ────────────────────────────────────────────────────────
  userId         String    @db.Uuid @map("user_id")
  restaurantId   String    @db.Uuid @map("restaurant_id")

  // ── Rol dentro del restaurante ─────────────────────────────────────────────
  permissionRole StaffRole @map("permission_role")

  // ── Estado ─────────────────────────────────────────────────────────────────
  /// false = el encargado ya no trabaja aquí.
  /// No se elimina para conservar trazabilidad.
  active         Boolean   @default(true)

  // ── Timestamps ─────────────────────────────────────────────────────────────
  createdAt      DateTime  @default(now()) @map("created_at")

  // ── Relaciones ─────────────────────────────────────────────────────────────
  user           User       @relation(fields: [userId], references: [id])
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id])

  // ── Restricciones ──────────────────────────────────────────────────────────
  /// Un usuario solo puede tener un rol por restaurante.
  @@unique([userId, restaurantId])

  // ── Índices ────────────────────────────────────────────────────────────────
  /// "¿qué restaurantes administra este usuario?" — JWT y dashboard
  @@index([userId, active])

  /// "¿qué staff tiene este restaurante?" — panel de encargados
  @@index([restaurantId, active])

  @@map("user_restaurants")
}

// =============================================================================
// RESTAURANT
// =============================================================================

/// Representa un restaurante registrado en la plataforma.
/// El propietario se vincula a través de UserRestaurant con rol OWNER.
model Restaurant {
  // ── Identidad ──────────────────────────────────────────────────────────────
  id          String           @id @default(uuid()) @db.Uuid
  name        String           @db.VarChar(150)
  slug        String           @unique @db.VarChar(160)
  description String?          @db.Text

  // ── Clasificación ──────────────────────────────────────────────────────────
  cuisineType String           @db.VarChar(80)  @map("cuisine_type")

  // ── Ubicación ──────────────────────────────────────────────────────────────
  address     String           @db.Text
  lat         Decimal          @db.Decimal(9, 6)
  lng         Decimal          @db.Decimal(9, 6)
  phone       String?          @db.VarChar(20)

  // ── Configuración de reservaciones ─────────────────────────────────────────
  capacity                  Int
  /// Factor reservable: capacity_reservable = capacity * factor
  reservationCapacityFactor Decimal @default(0.70) @db.Decimal(3, 2) @map("reservation_capacity_factor")
  /// Duración estándar en minutos. Base de todo cálculo de traslape.
  reservationDurationMin    Int     @default(90)   @map("reservation_duration_min")
  /// Anticipación mínima en horas, configurable por restaurante.
  minAdvanceHours           Int     @default(2)    @map("min_advance_hours")
  /// Días máximos en el futuro para reservar.
  maxAdvanceDays            Int     @default(30)   @map("max_advance_days")
  /// Zona horaria IANA para cálculos del job.
  timezone                  String  @default("America/Mexico_City") @db.VarChar(50)

  // ── Estado y calificación ──────────────────────────────────────────────────
  status      RestaurantStatus @default(ACTIVE)
  /// Promedio desnormalizado. Se actualiza al crear/editar/ocultar reseña.
  ratingAvg   Decimal?         @db.Decimal(2, 1) @map("rating_avg")
  ratingCount Int              @default(0)       @map("rating_count")

  // ── Timestamps ─────────────────────────────────────────────────────────────
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt      @map("updated_at")

  // ── Relaciones ─────────────────────────────────────────────────────────────
  staff         UserRestaurant[]
  businessHours BusinessHour[]

  // Relaciones futuras (se descomentan en su iteración correspondiente):
  // closures      SpecialClosure[]
  // photos        RestaurantPhoto[]
  // reservations  Reservation[]
  // reviews       Review[]

  @@map("restaurants")
}

// =============================================================================
// BUSINESS HOUR
// =============================================================================

/// Horario semanal del restaurante.
/// Un registro por día de la semana.
/// UNIQUE(restaurantId, dayOfWeek) garantiza un solo horario por día.
model BusinessHour {
  id           String    @id @default(uuid()) @db.Uuid
  restaurantId String    @db.Uuid @map("restaurant_id")
  dayOfWeek    DayOfWeek @map("day_of_week")

  /// Minutos desde medianoche. Ej: 480 = 08:00
  openTimeMin  Int       @map("open_time_min")

  /// Minutos desde medianoche. Ej: 1320 = 22:00
  closeTimeMin Int       @map("close_time_min")

  isClosed     Boolean   @default(false) @map("is_closed")

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  @@unique([restaurantId, dayOfWeek])
  @@map("business_hours")
}